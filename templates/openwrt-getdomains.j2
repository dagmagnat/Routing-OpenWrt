#!/bin/sh /etc/rc.common

START=99
STOP=10

BASE_DIR='/etc/domain-routing'
DOMAINS_DIR="$BASE_DIR/domains"
IPS_DIR="$BASE_DIR/ips"
GEN_DIR="$BASE_DIR/generated"
DNSMASQ_DIR='/etc/dnsmasq.d'
DNSMASQ_FILE="$DNSMASQ_DIR/90-domain-routing.conf"
IP_LOAD_FILE="$GEN_DIR/ip.lst"
SUBNET_LOAD_FILE="$GEN_DIR/subnet.lst"
COMMUNITY_LOAD_FILE="$GEN_DIR/community.lst"
DOMAIN_SET='vpn_domains'
NFT_FAMILY='inet'
NFT_TABLE='fw4'

{% if country == "russia-inside" %}
REMOTE_DOMAINS_URL='https://raw.githubusercontent.com/itdoginfo/allow-domains/main/Russia/inside-dnsmasq-nfset.lst'
{% elif country == "russia-outside" %}
REMOTE_DOMAINS_URL='https://raw.githubusercontent.com/itdoginfo/allow-domains/main/Russia/outside-dnsmasq-nfset.lst'
{% elif country == "ukraine" %}
REMOTE_DOMAINS_URL='https://raw.githubusercontent.com/itdoginfo/allow-domains/main/Ukraine/inside-dnsmasq-nfset.lst'
{% else %}
REMOTE_DOMAINS_URL=''
{% endif %}

fetch_url() {
    url="$1"
    out="$2"
    if command -v curl >/dev/null 2>&1; then
        curl -4 -fsSL --connect-timeout 10 --max-time 50 --retry 2 -o "$out" "$url"
    else
        wget -4 -q -T 50 -O "$out" "$url"
    fi
}

trim_line() {
    sed 's/#.*$//; s/\r$//; s/^[[:space:]]*//; s/[[:space:]]*$//'
}

valid_domain() {
    printf '%s\n' "$1" | grep -Eq '^([A-Za-z0-9_*-]+\.)+[A-Za-z]{2,}$'
}

normalize_domain() {
    printf '%s\n' "$1" | sed 's#^https\?://##; s#/.*$##; s/^\*\.//; s/^\.//; s/[[:space:]]//g' | tr 'A-Z' 'a-z'
}

write_local_domain_rules() {
    output="$1"
    for file in "$DOMAINS_DIR"/*.lst; do
        [ -f "$file" ] || continue
        while IFS= read -r raw || [ -n "$raw" ]; do
            line="$(printf '%s\n' "$raw" | trim_line)"
            [ -n "$line" ] || continue
            case "$line" in
                nftset=*|ipset=*) printf '%s\n' "$line" >> "$output" ;;
                *)
                    domain="$(normalize_domain "$line")"
                    if valid_domain "$domain"; then
                        printf 'nftset=/%s/4#%s#%s#%s\n' "$domain" "$NFT_FAMILY" "$NFT_TABLE" "$DOMAIN_SET" >> "$output"
                    fi
                    ;;
            esac
        done < "$file"
    done
}

update_domains() {
    mkdir -p "$DNSMASQ_DIR" "$DOMAINS_DIR" "$GEN_DIR"
    tmp="$GEN_DIR/domains.conf.tmp"
    remote_tmp="$GEN_DIR/remote-domains.tmp"
    remote_cache="$GEN_DIR/remote-domains.cache"
    printf '# Generated by getdomains\n' > "$tmp"

{% if list_domains %}
    if [ -n "$REMOTE_DOMAINS_URL" ]; then
        if fetch_url "$REMOTE_DOMAINS_URL" "$remote_tmp" && [ -s "$remote_tmp" ]; then
            cp "$remote_tmp" "$remote_cache"
            cat "$remote_tmp" >> "$tmp"
            printf '\n' >> "$tmp"
        elif [ -s "$remote_cache" ]; then
            echo 'Remote domain list unavailable; using cached copy'
            cat "$remote_cache" >> "$tmp"
            printf '\n' >> "$tmp"
        else
            echo 'Remote domain list unavailable and no cache exists; using local rules only'
        fi
    fi
{% endif %}

    write_local_domain_rules "$tmp"

    if dnsmasq --conf-file="$tmp" --test >/tmp/getdomains-dnsmasq-test.log 2>&1; then
        cp "$tmp" "$DNSMASQ_FILE"
        /etc/init.d/dnsmasq restart
    else
        echo 'Generated dnsmasq config is invalid; keeping previous valid file'
        cat /tmp/getdomains-dnsmasq-test.log
    fi
}

update_ip_lists() {
    mkdir -p "$GEN_DIR"
{% if list_subnet %}
    fetch_url https://antifilter.download/list/subnet.lst "$SUBNET_LOAD_FILE.tmp" && mv "$SUBNET_LOAD_FILE.tmp" "$SUBNET_LOAD_FILE"
{% endif %}
{% if list_ip %}
    fetch_url https://antifilter.download/list/ip.lst "$IP_LOAD_FILE.tmp" && mv "$IP_LOAD_FILE.tmp" "$IP_LOAD_FILE"
{% endif %}
{% if list_community %}
    fetch_url https://community.antifilter.download/list/community.lst "$COMMUNITY_LOAD_FILE.tmp" && mv "$COMMUNITY_LOAD_FILE.tmp" "$COMMUNITY_LOAD_FILE"
{% endif %}
{% if list_subnet or list_ip or list_community %}
    /etc/init.d/firewall restart
{% endif %}
}

start() {
    update_ip_lists
    update_domains
}

restart() {
    start
}

reload() {
    start
}
